{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "outDir": "static/build/library/",
    "paths": {
      "@common/*": ["src/common/*"],
      "@renderer/*": ["src/renderer/*"],
      "@main/*": ["src/main/*"],
      "*": ["node_modules/*", "types/*"]
    },
    "plugins": [
      {
        "name": "typescript-plugin-css-modules",
        "options": {
          "namedExports": false
        }
      }
    ]
  },
  "include": ["package.json", "webpack/vars.ts", "src/**/*", "types/*.d.ts", "src/common/i18n/translations/**/*.json"],
  "exclude": ["node_modules"]
}
